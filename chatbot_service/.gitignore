# ===========================
# AI/ML MODELS & DATA
# ===========================
# Large model files
*.bin
*.safetensors
*.h5
*.pkl
*.pickle
*.joblib
*.pt
*.pth
*.onnx
*.tflite
*.pb

# Model checkpoints (keep structure, ignore weights)
app/rag/generative/model/*/checkpoint-*/
!app/rag/generative/model/*/checkpoint-*/*.json
!app/rag/generative/model/*/checkpoint-*/*.txt
!app/rag/generative/model/*/checkpoint-*/README.md

# Final model weights (usually large files)
app/rag/generative/model/*/final/*.safetensors
app/rag/generative/model/*/final/*.bin
app/rag/generative/model/*/final/pytorch_model.bin
app/rag/generative/model/*/final/model.safetensors

# Training artifacts
app/rag/generative/model/*/checkpoint-*/optimizer.pt
app/rag/generative/model/*/checkpoint-*/rng_state.pth
app/rag/generative/model/*/checkpoint-*/scaler.pt
app/rag/generative/model/*/checkpoint-*/scheduler.pt
app/rag/generative/model/*/checkpoint-*/trainer_state.json
app/rag/generative/model/*/checkpoint-*/training_args.bin

# Embedding models cache
.sentence_transformers_cache/
sentence_transformers_cache/

# HuggingFace transformers cache
transformers_cache/
.transformers_cache/

